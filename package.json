{
  "name": "wexin-code-cli-bridge",
  "version": "0.1.0",
  "description": "Bridge WeChat messages to code CLIs (Claude Code, Codex, Gemini CLI) via iLink protocol",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "wcc": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "login": "tsx src/cli.ts login",
    "start": "tsx src/cli.ts start",
    "start:yolo": "tsx src/cli.ts start --yolo",
    "send": "tsx src/cli.ts send",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "qrcode-terminal": "0.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/qrcode-terminal": "^0.12.2",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
