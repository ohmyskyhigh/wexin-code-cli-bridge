{
  "name": "weixin-cc-connection",
  "version": "0.1.0",
  "description": "Bridge WeChat messages to Claude Code CLI via iLink protocol",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "login": "tsx src/index.ts login",
    "start": "tsx src/index.ts start",
    "start:yolo": "tsx src/index.ts start --yolo",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "qrcode-terminal": "0.12.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "@types/node": "^22.0.0",
    "@types/qrcode-terminal": "^0.12.2"
  }
}
